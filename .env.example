# Copy this file to .env and fill in the required values.
# Required for: docker compose --profile api up

# GraphHopper URL — defaults to hosted instance if not set.
# Uncomment and set to http://graphhopper:8989 if running local GH via --profile gh.
# GRAPHHOPPER_URL=http://graphhopper:8989

# JWT signing key — generate with: openssl rand -base64 32
JWT_KEY=

# Admin account credentials
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=
