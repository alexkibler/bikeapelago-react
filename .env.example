# Copy this file to the env file for the run mode you need:
#   .env.prod  - production full stack
#   .env.dev   - containerized dev full stack
#   .env.local - local dotnet/pnpm servers against the dev DB
#
# Always pass Docker Compose env files explicitly:
#   docker compose --env-file .env.prod -f docker-compose.deploy.yml up -d
#   docker compose --env-file .env.dev -f docker-compose.dev-db.yml up -d

# Uncomment to start all services with a single "docker compose up"
# (equivalent to --profile api --profile frontend --profile archipelago)
# COMPOSE_PROFILES=api,frontend,archipelago

# Bikeapelago Database (local Docker container)
DB_USER=osm
DB_PASSWORD=
DB_BIKEAPELAGO_PORT=5432

# OSM Discovery Database (shared infrastructure via reverse proxy)
OSM_DISCOVERY_HOST=localhost
OSM_DISCOVERY_PORT=5432
OSM_DISCOVERY_USER=osm
OSM_DISCOVERY_PASSWORD=

# Mapbox API key (required for routing)
MAPBOX_API_KEY=

# JWT signing key — generate with: openssl rand -base64 32
JWT_KEY=

# Admin account credentials
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=

# API connection strings. Set per environment:
#   .env.prod:  app DB host should be the production app DB container/service.
#   .env.dev:   app DB host should be postgis-bikeapelago-new, port 5432, database bikeapelago_new.
#   .env.local: app DB host should be localhost, port 5435, database bikeapelago_new.
ConnectionStrings__PostGis=
ConnectionStrings__OsmDiscovery=

# Local dotnet run port. Production/dev Compose set ASPNETCORE_URLS in compose.
ASPNETCORE_URLS=http://localhost:5056

# Production/OrbStack Deployment (for --profile prod-frontend)
# Set these to your deployed API URL if not running the local API container.
# API_PROXY_URL=https://api.bikeapelago.com/api/
# API_HUBS_URL=https://api.bikeapelago.com/hubs/
