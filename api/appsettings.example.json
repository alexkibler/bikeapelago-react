{
  "ConnectionStrings": {
    "PostGis": "Host=localhost;Port=5432;Database=bikeapelago;Username=osm;Password=osm_secret",
    "OsmDiscovery": "Host=localhost;Port=5432;Database=osm_discovery;Username=osm;Password=osm_secret"
  },
  "Mapbox": {
    "ApiKey": "YOUR_MAPBOX_KEY_HERE"
  },
  "Jwt": {
    "Key": "test-jwt-key-do-not-use-in-production"
  },
  "Admin": {
    "Email": "admin@localhost",
    "Password": "test-password-do-not-use-in-production"
  },
  "Usgs": {
    "ApiToken": "YOUR_USGS_TOKEN_HERE"
  },
  "PocketBase": {
    "BaseUrl": "http://pocketbase:8090"
  },
  "AllowedOrigins": [
    "https://bikeapelago.alexkibler.com"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "pocketbaseRoute": {
        "ClusterId": "pocketbaseCluster",
        "Match": {
          "Path": "/api/pb/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "pocketbaseCluster": {
        "Destinations": {
          "pbDest": {
            "Address": "http://pocketbase:8090"
          }
        }
      }
    }
  }
}