{
  "PocketBase": {
    "BaseUrl": "http://pocketbase:8090"
  },
  "AllowedOrigins": [
    "https://bikeapelago.alexkibler.com",
    "capacitor://localhost"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "pocketbaseRoute": {
        "ClusterId": "pocketbaseCluster",
        "Match": {
          "Path": "/api/pb/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "pocketbaseCluster": {
        "Destinations": {
          "pbDest": {
            "Address": "http://pocketbase:8090"
          }
        }
      }
    }
  }
}
