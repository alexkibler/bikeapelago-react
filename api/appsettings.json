{
  "OsmDiscovery": {
    "PbfPath": "./data/map.osm.pbf"
  },
  "PocketBase": {
    "BaseUrl": "http://pocketbase:8090"
  },
  "AllowedOrigins": [
    "https://bikeapelago.alexkibler.com"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "pocketbaseRoute": {
        "ClusterId": "pocketbaseCluster",
        "Match": {
          "Path": "/api/pb/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "graphhopperRoute": {
        "ClusterId": "graphhopperCluster",
        "Match": {
          "Path": "/api/gh/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "pocketbaseCluster": {
        "Destinations": {
          "pbDest": {
            "Address": "http://pocketbase:8090"
          }
        }
      },
      "graphhopperCluster": {
        "Destinations": {
          "ghDest": {
            "Address": "http://graphhopper:8989"
          }
        }
      }
    }
  }
}
