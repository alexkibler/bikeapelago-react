{
  "name": "@bikeapelago/bikeapelago-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:apworld": "node scripts/build-apworld.js",
    "dev": "pnpm run build:apworld && vite",
    "build": "pnpm run build:apworld && vite build",
    "tsc": "tsc -p tsconfig.app.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "cap:sync": "cap sync",
    "cap:build": "pnpm run build && cap sync",
    "cap:android": "pnpm run cap:build && cap open android",
    "cap:ios": "pnpm run cap:build && cap open ios",
    "cap:ios:configure": "node scripts/configure-ios-documents.js",
    "cap:ios:pods": "cd ios/App && pod install",
    "cap:ios:setup": "npx cap add ios && pnpm run build && npx cap sync ios && node scripts/configure-ios-documents.js && npx cap open ios"
  },
  "dependencies": {
    "@airbreather/archipelago.js": "^2.0.5-airbreather.6",
    "@bikeapelago/shared-data-fetching": "workspace:^",
    "@bikeapelago/shared-ui-components": "workspace:^",
    "@bikeapelago/shared-ui-form": "workspace:^",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0",
    "@microsoft/signalr": "^10.0.0",
    "@types/leaflet": "^1.9.21",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "canvas-confetti": "^1.9.4",
    "daisyui": "^5.5.19",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@bikeapelago/shared-configs": "workspace:^",
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@eslint/js": "^9.39.4",
    "@markw65/fit-file-writer": "^0.1.9",
    "@sports-alliance/sports-lib": "^11.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "adm-zip": "^0.5.17",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fit-file-parser": "^2.3.3",
    "globals": "^17.4.0",
    "gpx-builder": "^6.0.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
