# The URL of the API. In production, this can be empty if the frontend and API are on the same domain.
# For Capacitor (iOS/Android) builds this MUST be set to the full HTTPS URL of the backend,
# e.g. VITE_PUBLIC_API_URL=https://bikeapelago.alexkibler.com
# because there is no Vite dev proxy or same-origin assumption in a native WebView.
VITE_PUBLIC_API_URL=http://localhost:5054
